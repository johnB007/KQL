              "version": "KqlItem/1.0",
              "query": "Event\n| where TimeGenerated {TimeRange}\n| where EventLog in (\"DFS Replication\",\"File Replication Service\",\"Directory Service\")\n| where \"value::all\" in ({Computers}) or Computer in ({Computers})\n| where tolower(tostring(coalesce(_IsBillable, \"true\"))) == \"true\"\n| extend BilledGB=todouble(coalesce(_BilledSize, 0.0)) / 1000000000.0\n| summarize TotalGB=round(sum(BilledGB), 4) by Computer\n| top 20 by TotalGB desc",
