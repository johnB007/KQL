          {
            "type": 3,
            "name": "logvolume-by-device",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let pricePerGB = 2.76;\nlet bytesPerGB = 1000000000.0;\nEvent\n| where TimeGenerated {TimeRange}\n| where EventLog in (\"DFS Replication\",\"File Replication Service\",\"Directory Service\")\n| where \"value::all\" in ({Computers}) or Computer in ({Computers})\n| where tolower(tostring(coalesce(_IsBillable, \"true\"))) == \"true\"\n| extend BilledBytes=todouble(coalesce(_BilledSize, 0.0))\n| summarize EventCount=count(), TotalBytes=sum(BilledBytes), FirstSeen=min(TimeGenerated), LastSeen=max(TimeGenerated), ActiveDays=dcount(startofday(TimeGenerated)) by Computer\n| extend NormalizedDays=iff(ActiveDays < 1, 1.0, todouble(ActiveDays))\n| extend TotalGBRaw=TotalBytes / bytesPerGB\n| extend AvgKBPerEventRaw=iff(EventCount == 0, 0.0, (TotalBytes / 1000.0) / EventCount)\n| extend DailyAvgGBRaw=TotalGBRaw / NormalizedDays\n| extend Projected30DayGBRaw=DailyAvgGBRaw * 30.0\n| extend Estimated30DayCostUSDRaw=Projected30DayGBRaw * pricePerGB\n| order by TotalGBRaw desc\n| project Computer, EventCount, TotalGB=round(TotalGBRaw, 4), AvgKBPerEvent=round(AvgKBPerEventRaw, 2), DailyAvgGB=round(DailyAvgGBRaw, 4), Projected30DayGB=round(Projected30DayGBRaw, 4), Estimated30DayCostUSD=round(Estimated30DayCostUSDRaw, 2), FirstSeen, LastSeen",
              "size": 0,
