          {
            "type": 1,
            "content": {
              "json": "### Drill-Down: {SelectedVendor} — Device Network Events\n\nClick a vendor color in the chart above. Detailed records appear below. Use the **Export** button to download as CSV.",
              "style": "info"
            },
            "conditionalVisibility": {
              "parameterName": "SelectedVendor",
              "comparison": "isNotEqualTo",
              "value": ""
